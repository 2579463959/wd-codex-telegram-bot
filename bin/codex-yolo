#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
DEFAULT_CODEX_REAL_PATH="$REPO_ROOT/node_modules/.bin/codex"
if [[ ! -x "$DEFAULT_CODEX_REAL_PATH" ]]; then
  DEFAULT_CODEX_REAL_PATH="codex"
fi
CODEX_REAL_PATH="${CODEX_REAL_PATH:-$DEFAULT_CODEX_REAL_PATH}"

if [[ "${1:-}" == "exec" ]]; then
  shift
  exec "$CODEX_REAL_PATH" exec --dangerously-bypass-approvals-and-sandbox "$@"
fi

exec "$CODEX_REAL_PATH" "$@"
